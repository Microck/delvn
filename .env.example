# Azure Cosmos DB (required for --live mode)
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key-here

# Azure AI Search (required for --live mode)
SEARCH_ENDPOINT=https://your-search-service.search.windows.net
SEARCH_KEY=your-search-admin-key-here

# Azure OpenAI (required for embeddings in --live mode)
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-api-key-here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure AI Foundry (optional)
FOUNDRY_ENDPOINT=https://your-foundry-project.api.azureml.ms
FOUNDRY_API_KEY=your-foundry-api-key-here

# NVD API (optional - increases rate limit)
NVD_API_KEY=your-nvd-api-key-here

# AlienVault OTX (optional - enables subscribed pulses)
OTX_API_KEY=your-otx-api-key-here
